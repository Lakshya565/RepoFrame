# GitHub
# Optional token for the higher authenticated public-repository rate limit.
GITHUB_TOKEN=
# GitHub computes commit statistics lazily, so this route has a longer timeout.
GITHUB_COMMIT_STATS_TIMEOUT_SECONDS=20

# OpenAI
# Backend-only secret. RepoFrame pins gpt-5.6-luna in code.
OPENAI_API_KEY=
OPENAI_MAX_OUTPUT_TOKENS=6000
# Used for structured generation and the investigator's tool-free final verdict.
# Function-tool turns automatically use "none", as required by Chat Completions.
OPENAI_REASONING_EFFORT=medium
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2

# Evidence Investigator
# Hard bounds on model turns, tool calls, and extra repository reads.
VERIFY_MAX_ITERATIONS=8
VERIFY_MAX_TOOL_CALLS=12
VERIFY_MAX_ADDITIONAL_FILES=4
VERIFY_MAX_ADDITIONAL_CHARS=24000

# Evidence and prompt limits
MAX_SELECTED_FILES=12
MAX_CHARS_PER_FILE=12000
MAX_TOTAL_PROMPT_CHARS=60000
MAX_FILE_SIZE_BYTES=100000

# Enforced OpenAI spend caps
# Applied when Supabase is configured. Every successful investigator turn counts
# as a model call, rather than charging a multi-turn investigation as one call.
MAX_LLM_CALLS_PER_USER_PER_DAY=16
MAX_LLM_CALLS_PER_DAY=300

# Browser origins allowed to call the backend, comma-separated.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase persistence and authentication
# All values in this section are backend-only. The service-role key bypasses Row
# Level Security, so every query must remain explicitly scoped by user_id.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional legacy HS256 secret. Modern ES256/RS256 projects use public JWKS.
SUPABASE_JWT_SECRET=

# GitHub App repository access
# Installation tokens are short-lived and remain in process memory only.
GITHUB_APP_ID=
# Provide either inline PEM contents or an absolute path outside the repository.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_WEBHOOK_SECRET=

# Signed-out demo repository
DEMO_REPO_OWNER=Lakshya565
DEMO_REPO_NAME=RepoFrame
