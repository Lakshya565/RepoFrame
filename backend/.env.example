# ── GitHub ──────────────────────────────────────────────────────────────────
# Optional: raises GitHub REST API rate limits for public repository metadata.
GITHUB_TOKEN=

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Required for Phase 10+ generation. Backend-only — never expose to frontend.
OPENAI_API_KEY=
# RepoFrame is pinned in code to gpt-5.6-luna for generation and agentic work.
# There is deliberately no model environment override.
# Caps completion length. On reasoning models this budget also covers reasoning
# tokens, so keep it generous enough that the JSON answer is not truncated.
OPENAI_MAX_OUTPUT_TOKENS=6000
# Reasoning effort for structured generation and the verifier's tool-free final
# verdict (minimal | low | medium | high). Reasoning-model function-tool turns
# automatically use "none", as required by Chat Completions.
OPENAI_REASONING_EFFORT=medium
# Per-request timeout in seconds (SDK default is 600 — too long for a live call).
OPENAI_TIMEOUT_SECONDS=60
# Automatic retries for transient errors (exponential backoff, honors Retry-After).
OPENAI_MAX_RETRIES=2

# ── Claim Verification Agent (Phase 12) ─────────────────────────────────────
# Hard bounds on the verification agent loop. Max model turns, including the
# reserved tool-free final verdict, and max evidence tool calls across prior turns.
VERIFY_MAX_ITERATIONS=8
VERIFY_MAX_TOOL_CALLS=12
# On-demand reads beyond the initial deterministic evidence bundle.
VERIFY_MAX_ADDITIONAL_FILES=4
VERIFY_MAX_ADDITIONAL_CHARS=24000

# ── Evidence / Prompt Size Limits ───────────────────────────────────────────
# Maximum number of files included in one evidence bundle.
MAX_SELECTED_FILES=12
# Maximum characters read from a single file.
MAX_CHARS_PER_FILE=12000
# Hard ceiling on total evidence characters passed to OpenAI.
MAX_TOTAL_PROMPT_CHARS=60000
# Files larger than this are skipped before download (GitHub API limit).
MAX_FILE_SIZE_BYTES=100000

# ── Request / Abuse Caps (Phase 16) ─────────────────────────────────────────
# NOTE: these three are legacy PLACEHOLDERS (not enforced). The enforced spend
# caps are the MAX_LLM_CALLS_* pair below.
MAX_ANALYSES_PER_SESSION=10
MAX_ANALYSES_PER_IP_PER_DAY=20
MAX_ANALYSES_PER_DAY=500

# ── Enforced Spend Caps (Phase 16.3) ────────────────────────────────────────
# Daily caps on paid OpenAI calls, ENFORCED only when Supabase is configured (the
# no-login dev flow is unlimited). Quotas sum usage_metrics.model_calls, so every
# successful turn of a multi-turn verification is counted rather than charging the
# entire investigation as one request.
MAX_LLM_CALLS_PER_USER_PER_DAY=16
MAX_LLM_CALLS_PER_DAY=300

# ── CORS (Phase 16.4 — deployment) ──────────────────────────────────────────
# Comma-separated browser origins allowed to call the API. Defaults to the local
# dev frontend. In production set this to your deployed frontend origin(s), e.g.
# https://repoframe.vercel.app
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Optional Access Gate (Phase 15) ─────────────────────────────────────────
# If set, early deployments can require this shared password before analysis.
# Leave blank to disable. Replace with Supabase Auth in Phase 15.
ACCESS_PASSWORD=

# ── Supabase (Phase 15) ─────────────────────────────────────────────────────
# Persistence + auth. ALL backend-only — never expose to the frontend (only the
# NEXT_PUBLIC_SUPABASE_* URL + anon key belong in the frontend env). Leave every
# value blank to keep the no-login, public-repo dev flow (is_configured() = False).
# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=
# Service-role key — BYPASSES Row Level Security, so treat it like the OpenAI key.
# Backend only; every query made with it must be scoped by user_id in code.
SUPABASE_SERVICE_ROLE_KEY=
# OPTIONAL / legacy: only for projects that sign tokens with a shared HS256 secret.
# Projects on Supabase's asymmetric JWT signing keys (ES256/RS256) have no such
# secret — 15.1 verifies those against the public JWKS derived from SUPABASE_URL.
# Leave blank unless your project explicitly uses a legacy shared secret.
SUPABASE_JWT_SECRET=

# ── GitHub App (Phase 15.4 — repo access) ───────────────────────────────────
# Backend-only. Reads a user's public/private repos via short-lived installation
# tokens that are never stored. Register a GitHub App (Contents + Metadata: read-
# only) and fill these in. Leave blank to keep public-repo-only access.
# App ID (number on the App's General page).
GITHUB_APP_ID=
# App slug (last segment of https://github.com/apps/<slug>).
GITHUB_APP_SLUG=
# Absolute path to the private-key .pem. Store the file OUTSIDE the repo.
GITHUB_APP_PRIVATE_KEY_PATH=
# Webhook HMAC secret. Blank while the webhook is inactive (local dev).
GITHUB_APP_WEBHOOK_SECRET=
